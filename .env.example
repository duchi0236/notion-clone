# ClawNote Database
DATABASE_URL="postgresql://clawnote:clawnote@localhost:5432/clawnote?schema=public"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"

# Optional OAuth
# GITHUB_ID=""
# GITHUB_SECRET=""
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# OpenClaw / Agent API
# Use this later when adding strict token verification middleware.
CLAWNOTE_AGENT_TOKEN="replace-with-agent-token"

# File storage, optional for future upload implementation
STORAGE_DRIVER="local"
UPLOAD_DIR="./uploads"
