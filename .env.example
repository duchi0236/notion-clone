# ClawNote Database
DATABASE_URL="postgresql://clawnote:clawnote@localhost:5432/clawnote?schema=public"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"

# Optional OAuth
# GITHUB_ID=""
# GITHUB_SECRET=""
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# OpenClaw / Agent API
# Change this before production. Agent APIs require Authorization: Bearer <CLAWNOTE_AGENT_TOKEN> when this is set to a real value.
CLAWNOTE_AGENT_TOKEN="dev-change-me-agent-token"

# File storage
STORAGE_DRIVER="local"
UPLOAD_DIR="public/uploads"
