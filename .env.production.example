NODE_ENV=production

DATABASE_URL=postgresql://claw:change-me-password@postgres:5432/clawnote
NEXTAUTH_URL=https://your-domain.com
NEXTAUTH_SECRET=replace-with-a-long-random-secret

CLAWNOTE_AGENT_TOKEN=replace-with-agent-token

