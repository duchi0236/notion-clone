// ClawNote - Personal AI knowledge and document workspace
// PostgreSQL + Prisma schema for Notion/Yuque-like documents, tables, memories, inbox, and OpenClaw integration.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  name        String?
  avatarUrl   String?
  password    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ownedWorkspaces Workspace[]       @relation("WorkspaceOwner")
  memberships     WorkspaceMember[]
  documents       Document[]        @relation("DocumentCreator")
  comments        Comment[]
  memories        AgentMemory[]
  apiTokens       ApiToken[]
}

model Workspace {
  id          String   @id @default(cuid())
  name        String
  icon        String   @default("🧠")
  description String?
  ownerId     String
  owner       User     @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members      WorkspaceMember[]
  documents    Document[]
  collections  Collection[]
  objects      KnowledgeObject[]
  memories     AgentMemory[]
  inboxItems   InboxItem[]
  agentRuns    AgentRun[]
  templates    Template[]
  apiTokens    ApiToken[]
}

model WorkspaceMember {
  id          String   @id @default(cuid())
  role        Role     @default(MEMBER)
  createdAt   DateTime @default(now())

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([workspaceId])
}

enum Role {
  OWNER
  ADMIN
  MEMBER
  GUEST
}

model Document {
  id             String         @id @default(cuid())
  title          String         @default("Untitled")
  icon           String?        @default("📄")
  coverImage     String?
  type           DocumentType   @default(DOC)
  status         DocumentStatus @default(DRAFT)
  parentId       String?
  sortIndex      Int            @default(0)

  contentJson    Json
  contentHtml    String         @db.Text
  contentText    String         @db.Text
  summary        String?        @db.Text
  tags           String[]       @default([])

  isFavorite     Boolean        @default(false)
  isPublished    Boolean        @default(false)
  isArchived     Boolean        @default(false)
  agentReadable  Boolean        @default(true)
  agentWritable  Boolean        @default(false)

  workspaceId    String
  workspace      Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  createdById    String
  createdBy      User           @relation("DocumentCreator", fields: [createdById], references: [id])

  parent         Document?      @relation("DocumentChildren", fields: [parentId], references: [id])
  children       Document[]     @relation("DocumentChildren")
  blocks         Block[]
  comments       Comment[]
  versions       DocumentVersion[]
  objects        KnowledgeObject[]
  collectionRows CollectionRow[]
  searchIndex    SearchIndex?

  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([workspaceId, parentId])
  @@index([workspaceId, updatedAt])
  @@index([workspaceId, isArchived])
}

enum DocumentType {
  DOC
  NOTE
  PROJECT
  SOP
  SOURCE
  MEETING
  AGENT_LOG
}

enum DocumentStatus {
  DRAFT
  ACTIVE
  REVIEW
  PUBLISHED
  ARCHIVED
}

model Block {
  id            String    @id @default(cuid())
  type          BlockType
  content       Json
  properties    Json?
  sortIndex     Int       @default(0)
  parentBlockId String?

  documentId    String
  document      Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  parentBlock   Block?    @relation("BlockChildren", fields: [parentBlockId], references: [id])
  children      Block[]   @relation("BlockChildren")

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([documentId, sortIndex])
}

enum BlockType {
  TEXT
  HEADING_1
  HEADING_2
  HEADING_3
  BULLETED_LIST
  NUMBERED_LIST
  TO_DO
  TOGGLE
  QUOTE
  DIVIDER
  CODE
  IMAGE
  VIDEO
  FILE
  BOOKMARK
  CALLOUT
  TABLE
  TABLE_ROW
  EMBED
  DATABASE
  AI_SUMMARY
  AI_MEMORY
}

model Collection {
  id          String   @id @default(cuid())
  name        String
  icon        String   @default("📊")
  description String?
  schema      Json
  views       Json
  type        CollectionType @default(TABLE)
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  rows        CollectionRow[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([workspaceId])
}

enum CollectionType {
  TABLE
  BOARD
  GALLERY
  CALENDAR
  TASKS
}

model CollectionRow {
  id           String     @id @default(cuid())
  collectionId String
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  documentId   String?
  document     Document?  @relation(fields: [documentId], references: [id])
  data         Json
  sortIndex    Int        @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([collectionId, sortIndex])
}

model KnowledgeObject {
  id          String   @id @default(cuid())
  type        String
  title       String
  properties  Json
  relations   Json?
  documentId  String?
  document    Document? @relation(fields: [documentId], references: [id])
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([workspaceId, type])
}

model AgentMemory {
  id          String       @id @default(cuid())
  scope       MemoryScope  @default(WORKSPACE)
  content     String       @db.Text
  summary     String?
  tags        String[]     @default([])
  sourceType  String?
  sourceId    String?
  confidence  Float        @default(1)
  status      MemoryStatus @default(PENDING)

  workspaceId String
  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdById String?
  createdBy   User?        @relation(fields: [createdById], references: [id])

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([workspaceId, status])
}

enum MemoryScope {
  USER
  WORKSPACE
  PROJECT
  AGENT
}

enum MemoryStatus {
  PENDING
  ACCEPTED
  REJECTED
  ARCHIVED
}

model InboxItem {
  id          String      @id @default(cuid())
  source      InboxSource
  title       String
  content     String      @db.Text
  raw         Json?
  status      InboxStatus @default(UNPROCESSED)
  workspaceId String
  workspace   Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([workspaceId, status])
}

enum InboxSource {
  MANUAL
  OPENCLAW
  WEB_CLIP
  GITHUB
  FILE
  CHAT
}

enum InboxStatus {
  UNPROCESSED
  CONVERTED
  ARCHIVED
}

model AgentRun {
  id          String   @id @default(cuid())
  agentName   String
  input       Json
  output      Json?
  status      String
  documentIds String[] @default([])
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([workspaceId, createdAt])
}

model Comment {
  id         String   @id @default(cuid())
  content    String   @db.Text
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  authorId   String
  author     User     @relation(fields: [authorId], references: [id])
  parentId   String?
  parent     Comment? @relation("CommentReplies", fields: [parentId], references: [id])
  replies    Comment[] @relation("CommentReplies")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([documentId])
}

model DocumentVersion {
  id          String   @id @default(cuid())
  documentId  String
  document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  version     Int
  changedBy   String
  snapshot    Json
  diff        Json?
  reason      String?
  createdAt   DateTime @default(now())

  @@unique([documentId, version])
  @@index([documentId, createdAt])
}

model Template {
  id          String   @id @default(cuid())
  title       String
  icon        String   @default("📄")
  description String?
  category    String
  contentJson Json
  contentHtml String   @db.Text
  tags        String[] @default([])
  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SearchIndex {
  id          String   @id @default(cuid())
  documentId  String   @unique
  document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  title       String
  text        String   @db.Text
  summary     String?  @db.Text
  tags        String[] @default([])
  embedding   Json?
  updatedAt   DateTime @updatedAt
}

model ApiToken {
  id          String   @id @default(cuid())
  name        String
  tokenHash   String   @unique
  scopes      String[] @default([])
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?     @relation(fields: [userId], references: [id])
  lastUsedAt  DateTime?
  createdAt   DateTime @default(now())

  @@index([workspaceId])
}
